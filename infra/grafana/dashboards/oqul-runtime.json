{
  "title": "OQUL Distributed Runtime",
  "schemaVersion": 39,
  "version": 1,
  "panels": [
    {
      "type": "timeseries",
      "title": "Redis Commands",
      "targets": [
        {
          "expr": "rate(redis_commands_processed_total[1m])"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Redis Memory",
      "targets": [
        {
          "expr": "redis_memory_used_bytes"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Redis Connected Clients",
      "targets": [
        {
          "expr": "redis_connected_clients"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Redis Up",
      "targets": [
        {
          "expr": "up{job='redis'}"
        }
      ]
    }
  ]
}
